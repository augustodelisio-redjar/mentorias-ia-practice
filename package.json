{
  "name": "practica-ia",
  "version": "0.1.0",
  "private": true,
  "description": "Starter backend para la mentoría práctica de GitHub Copilot en VS Code.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:init": "tsx src/db/init.ts",
    "test": "tsx --test src/test/**/*.test.ts"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "express": "^4.21.2",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "@types/sql.js": "^1.4.11",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
